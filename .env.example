# LLM enrichment
ANTHROPIC_API_KEY=

# Supabase — server
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, bypasses RLS — never expose to the client

# Supabase — browser (same URL/anon-key, exposed for the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Monitoring cron — Vercel injects this as `Authorization: Bearer …`
# on scheduled invocations of /api/monitor. Generate any long random
# string; the route fails closed if unset.
CRON_SECRET=

# Upstash Redis — rate limiter state (POST /api/p). Provision via the
# Vercel Marketplace → Upstash integration, which sets both vars
# automatically. If omitted, lib/rateLimit.ts falls back to per-
# instance in-memory token buckets (fine for local dev, not fit for
# production at any real traffic — an attacker hitting cold-starts
# or distributed IPs slips past).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
