# LLM enrichment
ANTHROPIC_API_KEY=

# Supabase — server
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, bypasses RLS — never expose to the client

# Supabase — browser (same URL/anon-key, exposed for the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Monitoring cron — Vercel injects this as `Authorization: Bearer …`
# on scheduled invocations of /api/monitor. Generate any long random
# string; the route fails closed if unset.
CRON_SECRET=
