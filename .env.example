# LLM enrichment
ANTHROPIC_API_KEY=

# Supabase — server
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, bypasses RLS — never expose to the client

# Supabase — browser (same URL/anon-key, exposed for the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Monitoring cron — Vercel injects this as `Authorization: Bearer …`
# on scheduled invocations of /api/monitor. Generate any long random
# string; the route fails closed if unset.
CRON_SECRET=

# Upstash Redis — rate limiter state (POST /api/p). Provision via the
# Vercel Marketplace → Upstash integration, which sets both vars
# automatically. If omitted, lib/rateLimit.ts falls back to per-
# instance in-memory token buckets (fine for local dev, not fit for
# production at any real traffic — an attacker hitting cold-starts
# or distributed IPs slips past).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash — durable crawl-job queue. Publishes from lib/jobQueue.ts,
# callbacks land at /api/worker/crawl (verified via the signing
# keys). Provisioned through the same Upstash Vercel integration as
# Redis above. If QSTASH_TOKEN is absent, lib/jobQueue.ts falls back
# to the in-process `waitUntil(runCrawlPipeline(...))` path — fine
# for local dev, no mid-pipeline retry in production.
#
# QSTASH_WORKER_URL is optional: when unset, the publisher derives
# `https://${VERCEL_URL}/api/worker/crawl` on Vercel deployments.
# Override only if you need to point at a specific host (custom
# domain pre-cutover, preview deployment from a different branch,
# tunnel for local testing, etc.).
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_WORKER_URL=
